# Neon Serverless Postgres
DATABASE_URL=postgres://...

# Admin Emails (comma-separated)
ADMIN_EMAILS=user1@example.com,user2@example.com

# Auth Settings
# AUTH_SECRET is no longer required for custom scrypt auth, 
# but may be used for other cryptographic signing if needed.
AUTH_DEV_USER_ID=...
AUTH_DEV_USER_EMAIL=brad.vargason@gmail.com
AUTH_DEV_USER_NAME=Brad Vargason
AUTH_DEV_USER_IMAGE=...

# Gemini API Key
GEMINI_API_KEY=...

# Vercel Blob Token
BLOB_READ_WRITE_TOKEN=...

# Required: Gemini Model Specification
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
GEMINI_PHASE_1A_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3.1-pro-preview

